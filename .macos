#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"

. "$REPO_ROOT/scripts/lib/common.sh"
. "$REPO_ROOT/scripts/lib/sudo.sh"
. "$REPO_ROOT/scripts/install/boring_notch.sh"
. "$REPO_ROOT/scripts/install/homebrew.sh"
. "$REPO_ROOT/scripts/install/macos_defaults.sh"
. "$REPO_ROOT/scripts/install/runtimes.sh"
. "$REPO_ROOT/scripts/install/shell.sh"
. "$REPO_ROOT/scripts/install/tailscale.sh"

ensure_command_line_tools() {
  if xcode-select -p >/dev/null 2>&1; then
    log_info "Xcode Command Line Tools already installed"
    return
  fi

  log_step "Installing Xcode Command Line Tools"
  xcode-select --install >/dev/null 2>&1 || true
  log_warn "Finish the Command Line Tools prompt if macOS shows it, then rerun ./install if needed."
}

mas_is_ready() {
  if ! command_exists mas; then
    return 1
  fi

  MAS_NO_AUTO_INDEX=1 mas list >/dev/null 2>&1
}

install_mas_apps() {
  local brewfile_mas="$REPO_ROOT/packages/macos/Brewfile.mas"
  local tmp_dir desired_ids_file installed_ids_file missing_ids_file
  local app_id
  local -a install_ids=()

  if [ ! -f "$brewfile_mas" ]; then
    log_warn "Skipping Mac App Store apps because $brewfile_mas was not found."
    return
  fi

  if ! mas_is_ready; then
    log_warn "Skipping Mac App Store apps because mas is unavailable or App Store access could not be verified."
    return
  fi

  tmp_dir="$(mktemp -d)"

  desired_ids_file="$tmp_dir/desired-mas-ids.txt"
  installed_ids_file="$tmp_dir/installed-mas-ids.txt"
  missing_ids_file="$tmp_dir/missing-mas-ids.txt"

  grep '^mas ' "$brewfile_mas" | sed -E 's/.*id:[[:space:]]*([0-9]+).*/\1/' | sort -u > "$desired_ids_file"
  MAS_NO_AUTO_INDEX=1 mas list | awk '{print $1}' | sort -u > "$installed_ids_file"
  comm -23 "$desired_ids_file" "$installed_ids_file" > "$missing_ids_file"

  if [ ! -s "$missing_ids_file" ]; then
    rm -rf "$tmp_dir"
    log_info "Mac App Store apps already match $brewfile_mas"
    return
  fi

  while IFS= read -r app_id; do
    [ -n "$app_id" ] && install_ids+=("$app_id")
  done < "$missing_ids_file"

  if [ "${#install_ids[@]}" -eq 0 ]; then
    rm -rf "$tmp_dir"
    log_info "Mac App Store apps already match $brewfile_mas"
    return
  fi

  log_step "Installing Mac App Store apps"
  sudo env MAS_NO_AUTO_INDEX=1 mas install "${install_ids[@]}"
  rm -rf "$tmp_dir"
}

ensure_github_ssh_key() {
  local ssh_dir="$HOME/.ssh"
  local key_path="$ssh_dir/github"
  local config_file="$ssh_dir/config"
  local comment

  if ! command_exists ssh-keygen; then
    log_error "ssh-keygen is required to generate the GitHub SSH key."
    exit 1
  fi

  mkdir -p "$ssh_dir"
  chmod 700 "$ssh_dir"

  if [ -f "$key_path" ]; then
    log_info "GitHub SSH key already exists at $key_path"
    return
  fi

  comment="${DOTFILES_GIT_EMAIL:-$(git config --global user.email 2>/dev/null || true)}"
  if [ -z "$comment" ]; then
    comment="github"
  fi

  log_step "Generating GitHub SSH key"
  ssh-keygen -t ed25519 -C "$comment" -f "$key_path" -N ""

  touch "$config_file"
  chmod 600 "$config_file"

  if ! grep -q 'IdentityFile ~/.ssh/github' "$config_file"; then
    cat >> "$config_file" <<'EOF'
Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/github
EOF
  fi

  if command_exists ssh-add; then
    ssh-add --apple-use-keychain "$key_path" >/dev/null 2>&1 || ssh-add "$key_path" >/dev/null 2>&1 || true
  fi

  log_info "Copy the public key with: pbcopy < $key_path.pub"
}

install_brew_bundles() {
  log_step "Installing shared CLI packages"
  brew bundle --file "$REPO_ROOT/packages/base/Brewfile"

  log_step "Installing macOS packages"
  brew bundle --file "$REPO_ROOT/packages/macos/Brewfile"

  install_mas_apps
}

configure_sudo_touch_id() {
  local sudo_pam_override="${sudo_pam:-${SUDO_PAM:-}}"

  if [ -n "$sudo_pam_override" ]; then
    log_info "Skipping Touch ID sudo setup because sudo_pam is already defined"
    return
  fi

  if [ ! -f /etc/pam.d/sudo_local.template ]; then
    log_warn "Skipping Touch ID sudo setup because /etc/pam.d/sudo_local.template was not found."
    return
  fi

  if [ -f /etc/pam.d/sudo_local ] && grep -Eq '^[[:space:]]*auth[[:space:]]+sufficient[[:space:]]+pam_tid\.so([[:space:]].*)?$' /etc/pam.d/sudo_local; then
    log_info "Touch ID sudo authentication already enabled"
    return
  fi

  log_step "Enabling Touch ID for sudo"
  sudo cp /etc/pam.d/sudo_local.template /etc/pam.d/sudo_local
  sudo perl -0pi -e 's/^#([[:space:]]*auth[[:space:]]+sufficient[[:space:]]+pam_tid\.so\h*)$/$1/m' /etc/pam.d/sudo_local
}

main() {
  local mode="${1:-full}"

  if [ "$(detect_platform)" != "macos" ]; then
    log_error ".macos can only run on macOS."
    exit 1
  fi

  acquire_sudo

  case "$mode" in
    full)
      ensure_command_line_tools
      ensure_homebrew
      if ! load_homebrew_env; then
        log_error "Homebrew is required but was not found after installation."
        exit 1
      fi
      install_brew_bundles
      install_macos_boring_notch
      install_macos_tailscale
      install_macos_runtimes
      install_macos_oh_my_zsh
      configure_sudo_touch_id
      apply_macos_defaults
      ensure_github_ssh_key
      ;;
    --post-link)
      if ! load_homebrew_env; then
        log_error "Homebrew is required but was not found after installation."
        exit 1
      fi
      "$REPO_ROOT/scripts/install/skills.sh"
      ;;
    --defaults)
      apply_macos_defaults
      ;;
    *)
      log_error "Unknown .macos mode: $mode"
      exit 1
      ;;
  esac
}

main "$@"
