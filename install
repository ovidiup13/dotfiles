#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"

. "$REPO_ROOT/scripts/lib/common.sh"
. "$REPO_ROOT/scripts/install/git.sh"
. "$REPO_ROOT/scripts/lib/sudo.sh"
. "$REPO_ROOT/scripts/lib/symlink.sh"

main() {
  local arg
  local platform
  local mode="full"
  local macos_profile="main"
  local macos_profile_set=0

  ensure_not_root
  log_step "Preparing installer"

  while [ "$#" -gt 0 ]; do
    arg="$1"

    case "$arg" in
      --skills)
        if [ "$mode" != "full" ]; then
          log_error "Only one install mode can be selected: --skills or --macos-defaults."
          exit 1
        fi

        mode="--skills"
        ;;
      --macos-defaults)
        if [ "$mode" != "full" ]; then
          log_error "Only one install mode can be selected: --skills or --macos-defaults."
          exit 1
        fi

        mode="--macos-defaults"
        ;;
      --macos-profile)
        shift
        if [ "$#" -eq 0 ]; then
          log_error "Missing value for --macos-profile. Expected remote or main."
          exit 1
        fi

        case "$1" in
          remote|main)
            macos_profile="$1"
            macos_profile_set=1
            ;;
          *)
            log_error "Invalid macOS profile: $1. Expected remote or main."
            exit 1
            ;;
        esac
        ;;
      *)
        log_error "Unknown install argument: $arg"
        exit 1
        ;;
    esac

    shift
  done

  platform="$(detect_platform)"

  if [ "$platform" != "macos" ] && [ "$macos_profile_set" -eq 1 ]; then
    log_error "--macos-profile is only supported on macOS."
    exit 1
  fi

  case "$mode" in
    full)
      ;;
    --skills)
      if [ "$platform" != "macos" ]; then
        log_error "Skills sync is currently supported only on macOS."
        exit 1
      fi

      log_step "Syncing macOS agent skills"
      "$REPO_ROOT/.macos" --post-link --macos-profile "$macos_profile"
      log_success "Skills sync complete"
      return
      ;;
    --macos-defaults)
      if [ "$platform" != "macos" ]; then
        log_error "macOS defaults sync is currently supported only on macOS."
        exit 1
      fi

      log_step "Applying macOS defaults"
      "$REPO_ROOT/.macos" --defaults --macos-profile "$macos_profile"
      log_success "macOS defaults applied"
      return
      ;;
    *)
      log_error "Unknown install mode: $mode"
      exit 1
      ;;
  esac

  acquire_sudo

  case "$platform" in
    macos)
      if [ "$macos_profile" = "remote" ]; then
        log_step "Running macOS remote setup"
        bash "$REPO_ROOT/.macos-remote"
      else
        log_step "Running macOS setup"
        "$REPO_ROOT/.macos" --macos-profile "$macos_profile"
      fi
      ;;
    ubuntu)
      log_step "Running Ubuntu setup"
      "$REPO_ROOT/.ubuntu"
      ;;
    *)
      log_error "Unsupported platform. This installer currently supports macOS and Ubuntu."
      exit 1
      ;;
  esac

  log_step "Linking managed dotfiles into $HOME"
  link_home_tree "$REPO_ROOT"

  configure_git_identity

  if [ "$platform" = "macos" ]; then
    log_step "Syncing macOS agent skills"
    "$REPO_ROOT/.macos" --post-link --macos-profile "$macos_profile"
  fi

  log_success "Install complete"
  log_info "Open a new shell session to pick up all changes."
}

main "$@"
